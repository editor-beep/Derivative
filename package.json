{
  "name": "workspace",
  "version": "1.0.0",
  "description": "Etymology English Game",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "npm run test:typecheck && npm run test:ci",
    "test:watch": "npm run test:compile && node --test --watch tests/**/*.test.cjs",
    "test:ci": "npm run test:compile && node --test tests/**/*.test.cjs",
    "test:compile": "tsc -p tsconfig.test.json",
    "test:typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "expo": "^55.0.14",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  }
}
