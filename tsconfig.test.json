{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "strict": true,
    "noEmit": false,
    "outDir": ".test-dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "*.ts",
    "*.tsx",
    "components/**/*.tsx",
    "src/**/*.ts"
  ],
  "exclude": [
    "vite.config.ts"
  ]
}
